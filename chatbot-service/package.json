{
  "name": "umkmku-chatbot-service",
  "version": "1.0.0",
  "description": "Independent Node.js service for AI product recommendations and chatbot streaming",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
