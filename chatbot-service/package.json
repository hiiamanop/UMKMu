  "dependencies": {
    "@ai-sdk/anthropic": "^0.0.43",
    "@ai-sdk/openai-compatible": "^0.1.16",
    "@anthropic-ai/sdk": "^0.24.3",
    "@supabase/supabase-js": "^2.45.1",
    "ai": "^3.4.33",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.15.0",
    "@vitest/ui": "^1.6.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
